          id: '456',
          name: 'Project Alpha',
          color: 'blue'
        },
        processing_generated_summary: false
      }),
      label: 'Call Data'
    },
    display: {
      type: 'dropdown',
      value: 'default',
      options: ['default', 'search'],
      label: 'Display Mode'
    },
    hideProject: {
      type: 'boolean',
      value: false,
      label: 'Hide Project'
    }
  });

  return (
    <CallRow
      call={JSON.parse(state.call.value)}
      display={state.display.value}
      hideProject={state.hideProject.value}
    />
  );
}



